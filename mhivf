* { box-sizing:border-box; }
body { margin:0; font-family:Inter, Arial, sans-serif; background:var(--bg); color:var(--ink); }
.header { padding:30px 36px 18px; background:linear-gradient(135deg,#151a2d,#2f3761); color:white; }
