<script>
const DATA = JSON.parse(document.getElementById('data').textContent);
const fmt = n => Number(n || 0).toLocaleString('en-IN', {maximumFractionDigits: n % 1 ? 1 : 0});
const metricSel = document.getElementById('metric');
const statusSel = document.getElementById('status');
const searchInp = document.getElementById('search');
DATA.metrics.forEach(m => metricSel.insertAdjacentHTML('beforeend', `<option value="${m}">${m}</option>`));
['Growing','Declining','Fluctuating','Stable / Mild change','Low-volume'].forEach(s => statusSel.insertAdjacentHTML('beforeend', `<option value="${s}">${s}</option>`));
function cls(s) { return s.replace(/ \/ Mild change/g,'').replace(/\s+/g,'-'); }
function renderKpis() {
  const c = DATA.summary.counts;
  document.getElementById('kpis').innerHTML = `
    <div class="card kpi"><div class="label">Total blog URLs</div><div class="value">${fmt(DATA.summary.blogs)}</div></div>
    <div class="card kpi"><div class="label">Total New User Traffic</div><div class="value">${fmt(DATA.summary.totalNewUsers)}</div></div>
    <div class="card kpi"><div class="label">Growing blogs</div><div class="value">${fmt(c['Growing'] || 0)}</div></div>
    <div class="card kpi"><div class="label">Declining / fluctuating</div><div class="value">${fmt((c['Declining']||0)+(c['Fluctuating']||0))}</div></div>`;
}
function renderList(id, arr) {
  document.getElementById(id).innerHTML = arr.map(x => `<div class="item"><div class="url">${x.url}</div><div class="sub">${x.sub}</div></div>`).join('');
}
function renderAggregate() {
  const metric = metricSel.value;
  document.getElementById('chartTitle').textContent = `Monthly aggregate trend — ${metric}`;
  const vals = DATA.aggregate[metric];
  const max = Math.max(...vals,1);
  document.getElementById('aggregateChart').innerHTML = vals.map((v,i) => `
    <div class="barbox"><div class="barnum">${fmt(v)}</div><div class="bar ${i===vals.length-1?'neg':''}" style="height:${Math.max(3,(v/max)*210)}px"></div><div class="month">${DATA.months[i].replace(' 202',' ’2')}</div></div>`).join('');
}
function renderRows() {
  const metric = metricSel.value;
  const status = statusSel.value;
  const q = searchInp.value.toLowerCase().trim();
  let rows = DATA.records.filter(r => (status==='All'||r.status===status) && (!q || r.url.toLowerCase().includes(q)));
  rows = rows.slice(0,124);
  document.getElementById('rows').innerHTML = rows.map(r => {
    const vals = r.metrics[metric];
    const max = Math.max(...vals,1);
    const total = vals.reduce((a,b)=>a+b,0);
    const spark = vals.map((v,i)=>`<span class="${i===vals.length-1?'last':''}" title="${DATA.months[i]}: ${fmt(v)}" style="height:${Math.max(2,(v/max)*40)}px"></span>`).join('');
    const chClass = r.absChange3m>=0 ? 'pos' : 'negtext';
    const ch = `${r.absChange3m>=0?'+':''}${fmt(r.absChange3m)} (${r.pctChange3m>=0?'+':''}${r.pctChange3m}%)`;
    return `<tr><td class="urlcell">${r.url}</td><td><span class="badge ${cls(r.status)}">${r.status}</span></td><td><div class="spark">${spark}</div></td><td class="number">${fmt(total)}</td><td class="number">${fmt(r.prev3m)}</td><td class="number">${fmt(r.recent3m)}</td><td class="number ${chClass}">${ch}</td><td class="number">${r.fluctuationScore}</td></tr>`;
  }).join('');
}
function renderAll() { renderAggregate(); renderRows(); }
renderKpis();
renderList('growing', DATA.summary.topGrowing);
renderList('declining', DATA.summary.topDeclining);
renderList('fluctuating', DATA.summary.topFluctuating);
renderAll();
metricSel.addEventListener('change', renderAll);
statusSel.addEventListener('change', renderRows);
searchInp.addEventListener('input', renderRows);
</script>
