.controls { display:flex; gap:12px; align-items:center; flex-wrap:wrap; margin:22px 0; }
select,input { border:1px solid var(--line); background:white; padding:10px 12px; border-radius:12px; font-size:14px; }
.grid2 { display:grid; grid-template-columns:1.1fr .9fr; gap:18px; }
.panel { padding:20px; }
.panel h2 { font-size:18px; margin:0 0 14px; }
.chart { display:flex; align-items:end; gap:10px; height:260px; padding:14px 6px 0; border-bottom:1px solid var(--line); }
.barbox { flex:1; display:flex; flex-direction:column; align-items:center; justify-content:flex-end; height:100%; min-width:42px; }
.bar { width:100%; max-width:50px; border-radius:9px 9px 0 0; background:linear-gradient(180deg,#628cff,#2f6feb); min-height:2px; position:relative; }
.bar.neg { background:linear-gradient(180deg,#f38a8a,#c63434); }
.barnum { font-size:11px; color:var(--muted); margin-bottom:6px; transform:rotate(-35deg); transform-origin:right; white-space:nowrap; }
.month { font-size:11px; color:var(--muted); margin-top:7px; white-space:nowrap; transform:rotate(-38deg); }
.note { background:#fff9e7; color:#795600; padding:12px 14px; border:1px solid #f2ddb1; border-radius:14px; font-size:13px; line-height:1.5; margin-bottom:18px; }
.lists { display:grid; grid-template-columns:repeat(3,1fr); gap:16px; margin:18px 0; }
.list { padding:18px; }
.list h3 { margin:0 0 12px; font-size:16px; }
.item { padding:10px 0; border-top:1px solid var(--line); }
.item:first-of-type { border-top:0; }
.item .url { font-size:13px; font-weight:700; word-break:break-word; }
.item .sub { font-size:12px; color:var(--muted); margin-top:4px; }
.badge { display:inline-block; padding:4px 8px; border-radius:999px; font-size:12px; font-weight:700; }
.Growing { background:#e7f7ed; color:var(--good); }
.Declining { background:#ffebeb; color:var(--bad); }
.Fluctuating { background:#fff4de; color:var(--warn); }
.Low-volume { background:#f0f1f5; color:#596071; }
.Stable { background:#eaf0ff; color:var(--blue); }
.tablewrap { margin-top:18px; overflow:auto; }
table { border-collapse:separate; border-spacing:0; width:100%; min-width:1100px; }
th,td { padding:12px 10px; border-bottom:1px solid var(--line); text-align:left; vertical-align:middle; font-size:13px; }
th { position:sticky; top:0; background:#fbfcff; z-index:1; color:#536077; font-size:12px; text-transform:uppercase; letter-spacing:.04em; }
.urlcell { font-weight:700; max-width:360px; word-break:break-word; }
.spark { display:flex; gap:3px; align-items:end; height:42px; min-width:220px; }
.spark span { display:block; width:12px; background:#6b8cff; border-radius:4px 4px 0 0; min-height:2px; }
.spark span.last { background:#a7b4d8; }
.number { font-variant-numeric:tabular-nums; white-space:nowrap; }
.pos { color:var(--good); font-weight:800; }
.negtext { color:var(--bad); font-weight:800; }
.footer { color:var(--muted); font-size:12px; margin-top:18px; line-height:1.5; }
@media (max-width:1000px) { .kpis,.grid2,.lists { grid-template-columns:1fr; } .wrap,.header { padding-left:18px; padding-right:18px; } }
</style>
</head>
